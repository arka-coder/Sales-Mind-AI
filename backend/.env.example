# ============================================================
# SalesMind AI — Backend Environment Variables
# Copy this file to .env and fill in your values.
# In production, set these in Render → Settings → Environment Variables
# ============================================================

# ── AI Models ───────────────────────────────────────────────
# Required: Groq LLM (https://console.groq.com)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# Optional: OpenAI Whisper STT (https://platform.openai.com)
OPENAI_API_KEY=your-openai-api-key

# Optional: ElevenLabs TTS (https://elevenlabs.io)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Database ─────────────────────────────────────────────────
# Required: Supabase (https://supabase.com → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Email ────────────────────────────────────────────────────
# Optional: Resend email API (https://resend.com)
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=sales@yourdomain.com
FROM_NAME=SalesMind AI

# ── Application ───────────────────────────────────────────────
APP_NAME=SalesMind AI
APP_VERSION=1.0.0
DEBUG=false

# IMPORTANT: Change this in production! Use a random 64-char string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-minimum-32-characters-long

# CORS: comma-separated list of allowed frontend origins
# Add your Vercel URL here: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── ChromaDB ─────────────────────────────────────────────────
# Local dev: ./chroma_db  |  Render free tier: /tmp/chroma_db  |  Render paid: /data/chroma_db
CHROMA_PERSIST_DIR=./chroma_db
